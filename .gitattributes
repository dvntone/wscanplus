# Enforce LF line endings for all text files — prevents CRLF from Windows editors
# breaking GitHub Actions YAML parsing (root cause of 0-job CI failures, fixed 2026-03-15)

* text=auto eol=lf

# Explicitly force LF for files that must never have CRLF
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf
*.kt   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.ts   text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf

# Binary files — no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.keystore binary
*.jks  binary
